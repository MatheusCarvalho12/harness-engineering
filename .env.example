# Broker / state store
REDIS_URL=redis://redis:6379/0

# Local LLM (primary provider)
OLLAMA_BASE_URL=http://host.docker.internal:11434
MODEL_NAME=llama3.2:3b

# OpenAI (fallback provider — leave OPENAI_API_KEY empty to disable fallback)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-5-nano-2025-08-07

# LLM call tuning
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.2

# Fault tolerance
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=1
RETRY_BACKOFF_MULTIPLIER=2

# Orchestration
RESULT_WAIT_TIMEOUT_SECONDS=180
MAX_REVISION_ROUNDS=1

# API gateway
API_HOST=0.0.0.0
API_PORT=8000

# LangSmith observability (set LANGSMITH_API_KEY to enable)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=harness-engineering
